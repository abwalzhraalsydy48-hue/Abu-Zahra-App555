<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface_container"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/outline_variant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Scan Type Label -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textScanType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="@color/on_surface_variant"
                tools:text="Deep Scan" />

            <!-- ScanProgressView -->
            <com.ultimaterecovery.pro.ui.widgets.ScanProgressView
                android:id="@+id/scanProgressView"
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:layout_marginTop="16dp"
                app:dotColor="@color/scan_progress_dot"
                app:glowColor="@color/scan_progress_glow"
                app:progressColorEnd="@color/scan_progress_end"
                app:progressColorStart="@color/scan_progress_start" />

            <!-- File Count -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textFileCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/on_surface"
                tools:text="142 files found" />

            <!-- Scan Status -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/textScanStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/on_surface_variant"
                tools:text="Scanning storage blocks..." />

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPauseScan"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Pause" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStopScan"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stop" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
