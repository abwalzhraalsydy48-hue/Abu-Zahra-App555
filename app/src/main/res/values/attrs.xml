<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ==================== ScanProgressView Custom Attributes ==================== -->
    <declare-styleable name="ScanProgressView">
        <attr name="progressColorStart" format="color" />
        <attr name="progressColorEnd" format="color" />
        <attr name="glowColor" format="color" />
        <attr name="dotColor" format="color" />
    </declare-styleable>

    <!-- ==================== StorageInfoView Custom Attributes ==================== -->
    <declare-styleable name="StorageInfoView">
        <attr name="donutBackgroundColor" format="color" />
        <attr name="centerTextColor" format="color" />
        <attr name="centerSubTextColor" format="color" />
    </declare-styleable>
    <declare-styleable name="BannerView">
        <attr name="bannerText" format="string"/>
    </declare-styleable>
    <declare-styleable name="CustomTabLayout">
        <attr name="tabPaddingHorizontal" format="dimension"/>
    </declare-styleable>
</resources>
