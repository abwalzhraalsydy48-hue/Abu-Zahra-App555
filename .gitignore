# ============================================================================
# Ultimate Recovery Pro - .gitignore
# ============================================================================

# ============================================================================
# Built application files
# ============================================================================
# *.apk  # Commented out to allow APK distribution
*.ap_
*.aab

# ============================================================================
# Files for the ART/Dalvik VM
# ============================================================================
*.dex

# ============================================================================
# Java class files
# ============================================================================
*.class

# ============================================================================
# Generated files
# ============================================================================
bin/
gen/
out/
# release/ folder allowed for APK distribution

# ============================================================================
# Gradle files
# ============================================================================
.gradle/
build/
local.properties

# ============================================================================
# Android Studio
# ============================================================================
.idea/
*.iml
*.iws
*.ipr
.navigation/
captures/

# ============================================================================
# Android Studio Navigation editor temp files
# ============================================================================
.nav/

# ============================================================================
# Android Studio captures folder
# ============================================================================
captures/

# ============================================================================
# IntelliJ
# ============================================================================
*.iml
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches
.idea/navEditor.xml

# ============================================================================
# Keystore files
# ============================================================================
# Uncomment the following lines if you do not want to check your keystore files in.
#*.jks
#*.keystore

# ============================================================================
# External native build folder generated in Android Studio 2.2 and later
# ============================================================================
.externalNativeBuild/
.cxx/

# ============================================================================
# Google Services (if applicable)
# ============================================================================
google-services.json

# ============================================================================
# Freeline
# ============================================================================
freeline.py
freeline/
freeline_project_description.json

# ============================================================================
# fastlane
# ============================================================================
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md

# ============================================================================
# Version control
# ============================================================================
vcs.xml

# ============================================================================
# lint
# ============================================================================
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/
lint-report.html
lint-results.xml

# ============================================================================
# Android Profiling
# ============================================================================
*.hprof

# ============================================================================
# MacOS
# ============================================================================
.DS_Store

# ============================================================================
# Windows
# ============================================================================
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================================================
# Linux
# ============================================================================
*~

# ============================================================================
# Log Files
# ============================================================================
*.log

# ============================================================================
# Package Files
# ============================================================================
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# ============================================================================
# Virtual machine crash logs
# ============================================================================
hs_err_pid*
replay_pid*

# ============================================================================
# Kotlin
# ============================================================================
*.kotlin_module

# ============================================================================
# Secrets / API keys
# ============================================================================
secrets.properties
api_keys.properties
*.keystore
*.jks

# ============================================================================
# Backup files
# ============================================================================
*~
*.swp
*.bak
build/\n.gradle/\njdk-bin/
